<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (uncomment on InfinityFree)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Protect sensitive files
    <FilesMatch "\.(env|sql|md|log)$">
        Require all denied
    </FilesMatch>
    <FilesMatch "^(config|db)\.php$">
        Require all denied
    </FilesMatch>
    Options -Indexes

    # Route /admin/* to Laravel backend
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^admin(/(.*))?$ backend/public/index.php [QSA,L]
</IfModule>
